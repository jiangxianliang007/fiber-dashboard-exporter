# Fiber Dashboard backend base URL (required)
# e.g. http://localhost:8080 or http://your-server:8080
TARGET_URL=http://localhost:8080

# Comma-separated networks to monitor (default: mainnet,testnet)
NETWORKS=mainnet,testnet

# Port for the Prometheus metrics server (default: 9101)
LISTEN_PORT=9101

# Seconds between scrapes (default: 15)
SCRAPE_INTERVAL=15

# HTTP request timeout in seconds (default: 5)
REQUEST_TIMEOUT=5

# Seconds after which a heartbeat is marked stale (default: 120)
STALE_THRESHOLD=120

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Path to endpoints YAML config file (default: endpoints.yaml)
ENDPOINTS_FILE=endpoints.yaml
